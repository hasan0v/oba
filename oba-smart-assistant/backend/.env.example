# Database
DATABASE_URL=postgresql://oba_user:oba_password@localhost:5432/oba_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-very-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google Cloud API Key (for Voice Search)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Firebase (for Push Notifications)
FIREBASE_SERVER_KEY=your_firebase_server_key_here

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5000","http://localhost:8000"]

# Environment
ENVIRONMENT=development
DEBUG=True
