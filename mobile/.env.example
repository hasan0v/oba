# OBASA — Environment variables (TEMPLATE)
#
# 1. Copy this file to `.env` (which is git-ignored).
# 2. Fill the values below.
# 3. Run the app with:
#
#    flutter run --dart-define-from-file=.env
#
# Or, if you prefer individual flags:
#
#    flutter run \
#      --dart-define=GEMINI_API_KEY=AIza... \
#      --dart-define=SUPABASE_URL=https://xxxxx.supabase.co \
#      --dart-define=SUPABASE_ANON_KEY=eyJhbGc...

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
