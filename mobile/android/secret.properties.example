# =============================================================================
# OBASA Android secrets — TEMPLATE
#
# 1. Copy this file to `secret.properties` (same folder).
# 2. Replace the values with your real keys.
# 3. The file `secret.properties` is git-ignored.
#
# These values are read by android/app/build.gradle.kts and:
#   - injected into AndroidManifest.xml as ${MAPS_API_KEY}
#   - mirrored to the Dart layer so `flutter build apk` works without
#     having to pass --dart-define-from-file=.env every time.
#
# CLI overrides via --dart-define always win at the Flutter layer.
# =============================================================================

MAPS_API_KEY=YOUR_GOOGLE_MAPS_ANDROID_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
